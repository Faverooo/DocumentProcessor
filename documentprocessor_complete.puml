"DocumentProcessing::Container" o-- "DocumentProcessing::Persistence::FileStorage"
"DocumentProcessing::Container" o-- "DocumentProcessing::Persistence::SplitRunRepository"
"DocumentProcessing::Container" o-- "DocumentProcessing::Persistence::DataItemRepository"
