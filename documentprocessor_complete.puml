@startuml DocumentProcessorClassRelationsOnly

skinparam linetype ortho
skinparam classAttributeIconSize 0
hide empty members

legend right
  |= Simbolo |= Tipo |
  | <|-- | Ereditarieta |
  | *-- | Composizione |
  | o-- | Aggregazione |
  | --  | Associazione |
  | ..> | Dipendenza |
endlegend

' Inheritance
ApplicationRecord <|-- Employee
ApplicationRecord <|-- UploadedDocument
ApplicationRecord <|-- ProcessingRun
ApplicationRecord <|-- ProcessingItem
ApplicationRecord <|-- ExtractedDocument
ApplicationRecord <|-- Sending
ApplicationRecord <|-- Template

ApplicationController <|-- DocumentsController
ApplicationController <|-- SendingsController
ApplicationController <|-- TemplatesController
ApplicationController <|-- LookupsController

ApplicationJob <|-- PdfSplitJob
ApplicationJob <|-- DataExtractionJob
ApplicationJob <|-- GenericFileProcessingJob

"ApplicationCable::Channel" <|-- DocumentProcessingChannel

' Domain model relations
UploadedDocument "1" *-- "0..*" ExtractedDocument
ProcessingRun "1" *-- "0..*" ProcessingItem

ProcessingRun "0..*" -- "0..1" UploadedDocument
ProcessingItem "0..*" -- "0..1" ExtractedDocument
ExtractedDocument "0..*" -- "0..1" Employee
Sending "0..*" -- "1" Employee
Sending "0..*" -- "1" ExtractedDocument
Sending "0..*" -- "0..1" Template

' Controller / Job dependencies (use Container)
DocumentsController ..> "DocumentProcessing::Container"
SendingsController ..> "DocumentProcessing::Container"
TemplatesController ..> "DocumentProcessing::Container"
LookupsController ..> "DocumentProcessing::Container"

PdfSplitJob ..> "DocumentProcessing::Container"
DataExtractionJob ..> "DocumentProcessing::Container"
GenericFileProcessingJob ..> "DocumentProcessing::Container"

' Keep direct model deps where controllers reference models directly
DocumentsController ..> UploadedDocument
DocumentsController ..> ExtractedDocument
SendingsController ..> Sending
SendingsController ..> Employee
SendingsController ..> ExtractedDocument
TemplatesController ..> Template

