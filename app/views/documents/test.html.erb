<div class="container mt-5">
  <div class="row">
    <div class="col-md-10 offset-md-1">
      <h1 class="mb-4">Pipeline Asincrona DocumentProcessor</h1>

      <div class="card">
        <div class="card-header bg-primary text-white">
          <h5 class="mb-0">Upload unico: split + processamento automatico</h5>
        </div>
        <div class="card-body">
          <p class="text-muted">
            Carica un PDF multi-documento. Il backend avvia lo split asincrono, poi processa ogni mini-PDF in job separati,
            inviando notifiche in tempo reale via WebSocket.
          </p>

          <form id="pipelineForm" enctype="multipart/form-data">
            <div class="mb-3">
              <label for="pipelineFile" class="form-label">Seleziona file PDF</label>
              <input type="file" class="form-control" id="pipelineFile" name="pdf" accept=".pdf" required>
            </div>
            <button type="submit" class="btn btn-primary w-100">Avvia Pipeline</button>
          </form>

          <div id="pipelineResults" class="mt-4"></div>
          <div id="documentsList" class="mt-3"></div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .result-section {
    margin-top: 20px;
    padding: 15px;
    border-radius: 5px;
  }

  .result-success {
    background-color: #d4edda;
    border: 1px solid #c3e6cb;
    color: #155724;
  }

  .result-info {
    background-color: #e7f3ff;
    border: 1px solid #b9ddff;
    color: #084b83;
  }

  .result-error {
    background-color: #f8d7da;
    border: 1px solid #f5c6cb;
    color: #721c24;
  }

  .doc-row {
    border: 1px solid #dcdcdc;
    border-radius: 6px;
    padding: 12px;
    margin-bottom: 12px;
    background: #fff;
  }

  .doc-row strong {
    display: block;
    margin-bottom: 8px;
    font-size: 1rem;
  }

  .doc-row-error {
    border-color: #f5c6cb;
    background: #fff8f8;
  }

  .meta-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.88rem;
    margin-bottom: 8px;
  }

  .meta-table th, .meta-table td {
    text-align: left;
    padding: 4px 8px;
    border-bottom: 1px solid #eee;
  }

  .meta-table th {
    color: #555;
    font-weight: 600;
  }

  .conf-badge {
    display: inline-block;
    color: #fff;
    border-radius: 4px;
    padding: 1px 7px;
    font-size: 0.82rem;
    font-weight: 600;
  }

  .conf-na {
    color: #aaa;
    font-size: 0.82rem;
  }

  .conf-details {
    margin-top: 6px;
    font-size: 0.88rem;
  }

  .conf-details summary {
    cursor: pointer;
    color: #0066cc;
    margin-bottom: 4px;
  }

  .ocr-pre {
    background: #f5f5f5;
    padding: 6px 10px;
    border-radius: 4px;
    font-family: monospace;
    font-size: 0.82rem;
    word-break: break-word;
  }
</style>

<script>
  const form = document.getElementById('pipelineForm');
  const fileInput = document.getElementById('pipelineFile');
  const resultsDiv = document.getElementById('pipelineResults');
  const documentsListDiv = document.getElementById('documentsList');

  form.addEventListener('submit', async (event) => {
    event.preventDefault();

    const selectedFile = fileInput.files[0];
    if (!selectedFile) {
      resultsDiv.innerHTML = '<div class="result-section result-error"><strong>Errore:</strong> seleziona un PDF.</div>';
      return;
    }

    const formData = new FormData();
    formData.append('pdf', selectedFile);

    resultsDiv.innerHTML = '<div class="result-section result-info">Upload in corso...</div>';
    documentsListDiv.innerHTML = '';

    try {
      const response = await fetch('<%= test_split_documents_path %>', {
        method: 'POST',
        body: formData,
        headers: {
          'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content
        }
      });

      const data = await response.json();

      if (data.status !== 'queued') {
        resultsDiv.innerHTML = `<div class="result-section result-error"><strong>Errore:</strong> ${escapeHtml(data.message || 'richiesta non valida')}</div>`;
        return;
      }

      resultsDiv.innerHTML = '<div class="result-section result-info">Pipeline avviata. Attendo evento di split...</div>';
      listenToPipelineEvents(data.job_id);
    } catch (error) {
      resultsDiv.innerHTML = `<div class="result-section result-error"><strong>Errore:</strong> ${escapeHtml(error.message)}</div>`;
    }
  });

  function listenToPipelineEvents(jobId) {
    subscribeToJob(jobId, (message, unsubscribe) => {
      if (message.event === 'split_completed') {
        if (message.status === 'error') {
          resultsDiv.innerHTML = `<div class="result-section result-error"><strong>Split fallito:</strong> ${escapeHtml(message.message || 'errore sconosciuto')}</div>`;
          unsubscribe();
          return;
        }

        resultsDiv.innerHTML = `
          <div class="result-section result-success">
            <strong>Split completato</strong>
            <div>Pagine originali: ${message.original_pages}</div>
            <div>Documenti generati: ${message.mini_pdfs_count}</div>
          </div>
          <div class="result-section result-info">Processamento destinatari in corso...</div>
        `;
        return;
      }

      if (message.event === 'document_processed') {
        appendDocumentRow(message);
        return;
      }

      if (message.event === 'processing_completed') {
        resultsDiv.innerHTML += `
          <div class="result-section result-success">
            <strong>Pipeline terminata</strong>
          </div>
        `;
        unsubscribe();
      }
    }, (errorMessage) => {
      resultsDiv.innerHTML = `<div class="result-section result-error"><strong>Errore WebSocket:</strong> ${escapeHtml(errorMessage)}</div>`;
    });
  }

  function appendDocumentRow(message) {
    const statusLabel = message.status === 'success' ? 'OK' : 'ERRORE';

    let body;
    if (message.status !== 'success') {
      body = `<div class="text-danger">Messaggio: ${escapeHtml(message.message || 'errore sconosciuto')}</div>`;
    } else {
      const rec = message.matched_recipient;
      const destinationText = rec
        ? `${rec.name} — ${rec.email || 'no email'} (${rec.employee_code || 'no codice'})`
        : (message.fallback_text ? `Nessun match DB — fallback: ${message.fallback_text.substring(0, 120)}` : 'Nessun destinatario estratto');

      const meta  = message.extracted_document_data || {};
      const conf  = message.extracted_confidence   || {};
      const glob  = conf.global   || {};
      const llm   = conf.llm      || {};
      const txtr  = conf.textract || {};

      const confBar = (val) => {
        const safeVal = val == null ? 0 : Number(val);
        const pct = Math.round(safeVal * 100);
        const color = pct >= 80 ? '#28a745' : pct >= 50 ? '#ffc107' : '#dc3545';
        return `<span class="conf-badge" style="background:${color}">${pct}%</span>`;
      };

      const confRow = (label, field) => `
        <tr>
          <td>${label}</td>
          <td>${confBar(glob[field])}</td>
          <td>${confBar(llm[field])}</td>
          <td>${confBar(txtr[field])}</td>
        </tr>`;

      body = `
        <table class="meta-table">
          <tr><th>Campo</th><th>Valore estratto</th></tr>
          <tr><td>Destinatario</td><td>${escapeHtml(destinationText)}</td></tr>
          <tr><td>Data</td><td>${escapeHtml(meta.date || '—')}</td></tr>
          <tr><td>Azienda</td><td>${escapeHtml(meta.company || '—')}</td></tr>
          <tr><td>Reparto</td><td>${escapeHtml(meta.department || '—')}</td></tr>
        </table>

        <details class="conf-details">
          <summary>Confidenza per campo</summary>
          <table class="meta-table">
            <tr><th>Campo</th><th>Globale</th><th>LLM</th><th>Textract</th></tr>
            ${confRow('Destinatario', 'recipient')}
            ${confRow('Data',         'date')}
            ${confRow('Azienda',      'company')}
            ${confRow('Reparto',      'department')}
          </table>
        </details>

        <details class="conf-details">
          <summary>Nomi grezzi estratti dal LLM</summary>
          <div class="ocr-pre">${(message.extracted_names || []).map(escapeHtml).join(', ') || 'nessuno'}</div>
        </details>
      `;
    }

    const row = document.createElement('div');
    row.className = `doc-row ${message.status === 'success' ? '' : 'doc-row-error'}`;
    row.innerHTML = `
      <strong>[${statusLabel}] ${escapeHtml(message.filename || 'N/A')}</strong>
      ${body}
    `;

    documentsListDiv.prepend(row);
  }

  function subscribeToJob(jobId, onData, onError) {
    const protocol = window.location.protocol === 'https:' ? 'wss' : 'ws';
    const socket = new WebSocket(`${protocol}://${window.location.host}/cable`);
    const identifier = JSON.stringify({ channel: 'DocumentProcessingChannel', job_id: jobId });

    const unsubscribe = () => {
      if (socket.readyState === WebSocket.OPEN) {
        socket.send(JSON.stringify({ command: 'unsubscribe', identifier }));
      }
      socket.close();
    };

    socket.addEventListener('open', () => {
      socket.send(JSON.stringify({ command: 'subscribe', identifier }));
    });

    socket.addEventListener('message', (event) => {
      const payload = JSON.parse(event.data);

      if (payload.type === 'welcome' || payload.type === 'ping' || payload.type === 'confirm_subscription') {
        return;
      }

      if (payload.type === 'reject_subscription') {
        onError('Sottoscrizione rifiutata dal server');
        unsubscribe();
        return;
      }

      if (payload.message) {
        onData(payload.message, unsubscribe);
      }
    });

    socket.addEventListener('error', () => {
      onError('Connessione WebSocket non disponibile');
    });
  }

  function escapeHtml(value) {
    const div = document.createElement('div');
    div.textContent = value || '';
    return div.innerHTML;
  }
</script>
