<div class="container mt-5">
  <div class="row">
    <div class="col-md-10 offset-md-1">
      <h1 class="mb-4">🧪 Test Servizi DocumentProcessor</h1>

      <div class="row">
        <!-- Test Split -->
        <div class="col-md-6 mb-4">
          <div class="card">
            <div class="card-header bg-primary text-white">
              <h5 class="mb-0">🔪 Test Split PDF</h5>
            </div>
            <div class="card-body">
              <p class="text-muted">Analizza un PDF multi-documento e lo divide in mini-PDF per ogni documento singolo.</p>
              
              <form id="splitForm" enctype="multipart/form-data">
                <div class="mb-3">
                  <label for="splitFile" class="form-label">Seleziona file PDF</label>
                  <input type="file" class="form-control" id="splitFile" name="pdf" accept=".pdf" required>
                </div>
                <button type="submit" class="btn btn-primary w-100">Testa Split</button>
              </form>

              <div id="splitResults" class="mt-4"></div>
            </div>
          </div>
        </div>

        <!-- Test Recipient -->
        <div class="col-md-6 mb-4">
          <div class="card">
            <div class="card-header bg-success text-white">
              <h5 class="mb-0">🤖 Test Estrazione Destinatari</h5>
            </div>
            <div class="card-body">
              <p class="text-muted">Estrae il testo con OCR, individua i nomi via LLM e li matcha con il database dipendenti.</p>
              
              <form id="recipientForm" enctype="multipart/form-data">
                <div class="mb-3">
                  <label for="recipientFile" class="form-label">Seleziona file PDF</label>
                  <input type="file" class="form-control" id="recipientFile" name="pdf" accept=".pdf" required>
                </div>
                <button type="submit" class="btn btn-success w-100">Testa Estrazione</button>
              </form>

              <div id="recipientResults" class="mt-4"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .loading {
    display: none;
    margin-top: 20px;
  }
  
  .loading.show {
    display: block;
  }
  
  .result-section {
    margin-top: 20px;
    padding: 15px;
    border-radius: 5px;
  }
  
  .result-success {
    background-color: #d4edda;
    border: 1px solid #c3e6cb;
    color: #155724;
  }
  
  .result-error {
    background-color: #f8d7da;
    border: 1px solid #f5c6cb;
    color: #721c24;
  }
  
  .ocr-text {
    background-color: #f5f5f5;
    padding: 10px;
    border-radius: 4px;
    max-height: 300px;
    overflow-y: auto;
    font-size: 12px;
    font-family: monospace;
  }
  
  .match-info {
    background-color: #e7f3ff;
    border-left: 4px solid #2196F3;
    padding: 10px;
    margin-top: 10px;
  }
</style>

<script>
  // Test Split
  document.getElementById('splitForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const formData = new FormData();
    const fileInput = document.getElementById('splitFile');
    formData.append('pdf', fileInput.files[0]);
    
    const resultsDiv = document.getElementById('splitResults');
    resultsDiv.innerHTML = '<div class="loading show"><span class="spinner-border spinner-border-sm me-2"></span>Caricamento in corso...</div>';
    
    try {
      const response = await fetch('<%= test_split_documents_path %>', {
        method: 'POST',
        body: formData,
        headers: {
          'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content
        }
      });
      
      const data = await response.json();
      
      if (data.status === 'queued') {
        resultsDiv.innerHTML = '<div class="result-section"><span class="spinner-border spinner-border-sm me-2"></span>Elaborazione in corso...</div>';
        listenForSplitResult(data.job_id, resultsDiv);
      } else {
        resultsDiv.innerHTML = `<div class="result-section result-error"><strong>❌ Errore:</strong> ${data.message}</div>`;
      }
    } catch (error) {
      resultsDiv.innerHTML = `<div class="result-section result-error"><strong>❌ Errore:</strong> ${error.message}</div>`;
    }
  });

  // Test Recipient
  document.getElementById('recipientForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const formData = new FormData();
    const fileInput = document.getElementById('recipientFile');
    formData.append('pdf', fileInput.files[0]);
    
    const resultsDiv = document.getElementById('recipientResults');
    resultsDiv.innerHTML = '<div class="loading show"><span class="spinner-border spinner-border-sm me-2"></span>Caricamento in corso...</div>';
    
    try {
      const response = await fetch('<%= test_recipient_documents_path %>', {
        method: 'POST',
        body: formData,
        headers: {
          'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content
        }
      });
      
      const data = await response.json();
      
      if (data.status === 'queued') {
        resultsDiv.innerHTML = '<div class="result-section"><span class="spinner-border spinner-border-sm me-2"></span>Elaborazione in corso...</div>';
        listenForRecipientResult(data.job_id, resultsDiv);
      } else {
        resultsDiv.innerHTML = `<div class="result-section result-error"><strong>❌ Errore:</strong> ${data.message}</div>`;
      }
    } catch (error) {
      resultsDiv.innerHTML = `<div class="result-section result-error"><strong>❌ Errore:</strong> ${error.message}</div>`;
    }
  });

  // Ascolta i risultati del split via WebSocket
  function listenForSplitResult(jobId, resultsDiv) {
    subscribeToJob(jobId, (data, unsubscribe) => {
      if (data.status === 'success') {
        resultsDiv.innerHTML = `
          <div class="result-section result-success">
            <h6>✅ Split completato</h6>
            <p><strong>Pagine originali:</strong> ${data.original_pages}</p>
            <p><strong>Mini-PDF creati:</strong> ${data.mini_pdfs_count}</p>
            <details>
              <summary>Mostra elenco file</summary>
              <ul style="margin-top: 10px;">
                ${data.mini_pdfs.map(pdf => `<li><code>${pdf}</code></li>`).join('')}
              </ul>
            </details>
          </div>
        `;
        unsubscribe();
      } else if (data.status === 'error') {
        resultsDiv.innerHTML = `<div class="result-section result-error"><strong>❌ Errore:</strong> ${data.message}</div>`;
        unsubscribe();
      }
    }, (message) => {
      resultsDiv.innerHTML = `<div class="result-section result-error"><strong>❌ Errore WebSocket:</strong> ${message}</div>`;
    });
  }

  // Ascolta i risultati dell'estrazione via WebSocket
  function listenForRecipientResult(jobId, resultsDiv) {
    subscribeToJob(jobId, (data, unsubscribe) => {
      if (data.status === 'success') {
        const matchHtml = data.matched_recipient 
          ? `<div class="match-info">
              <strong>✅ Destinatario trovato:</strong><br>
              Nome: ${data.matched_recipient.name}<br>
              Email: ${data.matched_recipient.email}<br>
              Codice: ${data.matched_recipient.employee_code}
            </div>`
          : data.fallback_text
            ? `<div class="match-info" style="border-left-color: #ff9800;">
                <strong>⚠️ Nessun match nel DB</strong><br>
                Testo grezzo: ${data.fallback_text.substring(0, 100)}...
              </div>`
            : '<div class="match-info">⚠️ Nessun destinatario estratto</div>';
        
        resultsDiv.innerHTML = `
          <div class="result-section result-success">
            <h6>✅ Estrazione completata</h6>
            
            <details>
              <summary><strong>📋 Nomi estratti dal LLM (${data.extracted_names.length})</strong></summary>
              <ul style="margin-top: 10px;">
                ${data.extracted_names.map(name => `<li>${name}</li>`).join('') || '<li><em>Nessun nome estratto</em></li>'}
              </ul>
            </details>
            
            <details style="margin-top: 10px;">
              <summary><strong>📄 Testo OCR (preview)</strong></summary>
              <div class="ocr-text">${escapeHtml(data.ocr_text.substring(0, 500))}...</div>
            </details>
            
            ${matchHtml}
          </div>
        `;
        unsubscribe();
      } else if (data.status === 'error') {
        resultsDiv.innerHTML = `<div class="result-section result-error"><strong>❌ Errore:</strong> ${data.message}</div>`;
        unsubscribe();
      }
    }, (message) => {
      resultsDiv.innerHTML = `<div class="result-section result-error"><strong>❌ Errore WebSocket:</strong> ${message}</div>`;
    });
  }

  function subscribeToJob(jobId, onData, onError) {
    const protocol = window.location.protocol === 'https:' ? 'wss' : 'ws';
    const socket = new WebSocket(`${protocol}://${window.location.host}/cable`);
    const identifier = JSON.stringify({ channel: 'DocumentProcessingChannel', job_id: jobId });

    const unsubscribe = () => {
      if (socket.readyState === WebSocket.OPEN) {
        socket.send(JSON.stringify({ command: 'unsubscribe', identifier }));
      }
      socket.close();
    };

    socket.addEventListener('open', () => {
      socket.send(JSON.stringify({ command: 'subscribe', identifier }));
    });

    socket.addEventListener('message', (event) => {
      const payload = JSON.parse(event.data);
      if (payload.type === 'welcome' || payload.type === 'ping' || payload.type === 'confirm_subscription') {
        return;
      }

      if (payload.type === 'reject_subscription') {
        onError('Sottoscrizione rifiutata dal server');
        unsubscribe();
        return;
      }

      if (payload.message) {
        onData(payload.message, unsubscribe);
      }
    });

    socket.addEventListener('error', () => {
      onError('Connessione non disponibile');
    });
  }

  function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }
</script>
